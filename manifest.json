{
  "manifest_version": 3,
  "name": "Slumber — Tab Suspender",
  "short_name": "Slumber",
  "version": "0.1.0",
  "description": "Suspend inactive tabs to reclaim memory. Lightweight, private, no telemetry.",

  "permissions": [
    "tabs",
    "storage",
    "alarms"
  ],

  "host_permissions": [
    "https://extensionpay.com/*"
  ],

  "background": {
    "service_worker": "background/worker.js"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16":  "icons/icon-16.png",
      "32":  "icons/icon-32.png",
      "48":  "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "Slumber"
  },

  "icons": {
    "16":  "icons/icon-16.png",
    "32":  "icons/icon-32.png",
    "48":  "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },

  "options_page": "options/options.html",

  "web_accessible_resources": [
    {
      "resources": ["suspended/suspended.html"],
      "matches":   ["<all_urls>"]
    }
  ],

  "content_scripts": [
    {
      "matches": ["https://extensionpay.com/*"],
      "js": ["ExtPay.js"],
      "run_at": "document_start"
    }
  ],

  "content_security_policy": {
    "extension_pages": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src https://extensionpay.com;"
  }
}
